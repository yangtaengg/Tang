<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/manualPairRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tang_bg"
    android:orientation="vertical"
    android:padding="20dp">

    <Button
        android:id="@+id/manualPairBackButton"
        style="@style/Widget.Tang.ButtonSecondary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/manual_pair_back" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="@string/manual_pair_screen_title"
        android:textAppearance="@style/TangTitleText" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/manual_pair_dialog_subtitle"
        android:textAppearance="@style/TangBodyText" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="@string/manual_pair_code_label"
        android:textAppearance="@style/TangBodyText" />

    <LinearLayout
        android:id="@+id/manualPairPinRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/pinDigit1"
            android:layout_width="44dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_pin_digit"
            android:digits="0123456789"
            android:gravity="center"
            android:imeOptions="actionNext"
            android:inputType="number"
            android:maxLength="1"
            android:textSize="20sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/pinDigit2"
            android:layout_width="44dp"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_pin_digit"
            android:digits="0123456789"
            android:gravity="center"
            android:imeOptions="actionNext"
            android:inputType="number"
            android:maxLength="1"
            android:textSize="20sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/pinDigit3"
            android:layout_width="44dp"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_pin_digit"
            android:digits="0123456789"
            android:gravity="center"
            android:imeOptions="actionNext"
            android:inputType="number"
            android:maxLength="1"
            android:textSize="20sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/pinDigit4"
            android:layout_width="44dp"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_pin_digit"
            android:digits="0123456789"
            android:gravity="center"
            android:imeOptions="actionNext"
            android:inputType="number"
            android:maxLength="1"
            android:textSize="20sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/pinDigit5"
            android:layout_width="44dp"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_pin_digit"
            android:digits="0123456789"
            android:gravity="center"
            android:imeOptions="actionNext"
            android:inputType="number"
            android:maxLength="1"
            android:textSize="20sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/pinDigit6"
            android:layout_width="44dp"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_pin_digit"
            android:digits="0123456789"
            android:gravity="center"
            android:imeOptions="actionDone"
            android:inputType="number"
            android:maxLength="1"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/manualPairErrorText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:textColor="@color/tang_error"
        android:textSize="13sp"
        android:visibility="gone" />

    <Button
        android:id="@+id/manualPairConnectButton"
        style="@style/Widget.Tang.ButtonPrimary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/manual_pair_confirm" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
